<div class="container">
  <h1>Progress Tracker - <%= @date.strftime("%B %Y") %></h1>
  
  <!-- Navigation -->
  <div class="navigation">
    <% prev_month = @date - 1.month %>
    <% next_month = @date + 1.month %>
    
    <%= link_to "← #{prev_month.strftime('%B %Y')}", monthly_progress_path(prev_month.year, prev_month.month), class: "nav-link" %>
    <%= link_to "Goals", goals_path, class: "nav-link" %>
    <%= link_to "#{next_month.strftime('%B %Y')} →", monthly_progress_path(next_month.year, next_month.month), class: "nav-link" %>
  </div>

  <% if @goals.any? %>
    <div class="progress-table">
      <table>
        <thead>
          <tr>
            <th>Goal</th>
            <% (1..@days_in_month).each do |day| %>
              <th><%= day %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @goals.each do |goal| %>
            <tr>
              <td class="goal-name"><%= goal.name %></td>
              <% (1..@days_in_month).each do |day| %>
                <% current_date = Date.new(@year, @month, day) %>
                <% progress = @daily_progresses[[goal.id, current_date]] %>
                <% status = progress&.status || 0 %>
                <td class="progress-cell">
                  <div class="progress-circle status-<%= status %>" 
                       data-goal-id="<%= goal.id %>" 
                       data-date="<%= current_date %>"
                       data-status="<%= status %>">
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Journal Entries Section -->
    <div class="journal-section">
      <h2>Journal Entries</h2>
      <div class="journal-grid">
        <% (1..@days_in_month).each do |day| %>
          <% current_date = Date.new(@year, @month, day) %>
          <% journal_entry = @journal_entries[current_date] %>
          <div class="journal-day">
            <div class="journal-date"><%= day %></div>
            <div class="journal-content">
              <% if journal_entry %>
                <div class="journal-text"><%= truncate(journal_entry.content, length: 100) %></div>
                <%= link_to "Edit", edit_journal_entry_path(journal_entry), class: "journal-link" %>
              <% else %>
                <%= link_to "Add Entry", new_journal_entry_path(date: current_date), class: "journal-link" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="no-goals">
      <p>No goals have been created yet.</p>
      <%= link_to "Create your first goal", new_goal_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .nav-link {
    padding: 10px 15px;
    text-decoration: none;
    background: #007bff;
    color: white;
    border-radius: 5px;
  }

  .progress-table {
    overflow-x: auto;
    margin-bottom: 30px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  th, td {
    border: 1px solid #ddd;
    padding: 8px;
    text-align: center;
  }

  th {
    background: #f8f9fa;
    font-weight: bold;
  }

  .goal-name {
    text-align: left;
    font-weight: bold;
    min-width: 120px;
  }

  .progress-cell {
    width: 40px;
    height: 40px;
    padding: 5px;
  }

  .progress-circle {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 2px solid #ccc;
    cursor: pointer;
    margin: 0 auto;
    transition: all 0.2s;
  }

  .progress-circle:hover {
    transform: scale(1.1);
  }

  .status-0 {
    background: white;
  }

  .status-1 {
    background: linear-gradient(45deg, #28a745 50%, white 50%);
  }

  .status-2 {
    background: #28a745;
  }

  .journal-section {
    margin-top: 30px;
  }

  .journal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .journal-day {
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 5px;
  }

  .journal-date {
    font-weight: bold;
    margin-bottom: 5px;
  }

  .journal-text {
    font-size: 12px;
    margin-bottom: 5px;
  }

  .journal-link {
    font-size: 11px;
    color: #007bff;
    text-decoration: none;
  }

  .no-goals {
    text-align: center;
    padding: 50px;
  }

  .btn {
    display: inline-block;
    padding: 10px 20px;
    background: #007bff;
    color: white;
    text-decoration: none;
    border-radius: 5px;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const circles = document.querySelectorAll('.progress-circle');
  
  circles.forEach(circle => {
    circle.addEventListener('click', function() {
      const goalId = this.dataset.goalId;
      const date = this.dataset.date;
      const currentStatus = parseInt(this.dataset.status);
      
      // Cycle through statuses: 0 -> 1 -> 2 -> 0
      const newStatus = (currentStatus + 1) % 3;
      
      // Update the visual immediately
      this.className = `progress-circle status-${newStatus}`;
      this.dataset.status = newStatus;
      
      // Send update to server
      fetch(`/progress/${new Date(date).getFullYear()}/${new Date(date).getMonth() + 1}/${goalId}/${date}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ status: newStatus })
      })
      .then(response => response.json())
      .then(data => {
        if (!data.success) {
          // Revert on error
          this.className = `progress-circle status-${currentStatus}`;
          this.dataset.status = currentStatus;
          alert('Error updating progress: ' + data.errors.join(', '));
        }
      })
      .catch(error => {
        // Revert on error
        this.className = `progress-circle status-${currentStatus}`;
        this.dataset.status = currentStatus;
        alert('Error updating progress: ' + error.message);
      });
    });
  });
});
</script>
