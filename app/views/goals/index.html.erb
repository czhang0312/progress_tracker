<div class="container">
  <h1>Goals</h1>
  
  <%= link_to "New Goal", new_goal_path, class: "btn btn-primary" %>
  
  <% if @goals.any? %>
    <div class="goals-list">
      <% @goals.each do |goal| %>
        <div class="goal-item">
          <div class="goal-info">
            <h3><%= goal.name %></h3>
            <p><%= goal.description %></p>
          </div>
          <div class="goal-actions">
            <%= link_to "Edit", edit_goal_path(goal), class: "btn btn-secondary" %>
            <%= button_to "Delete", goal_path(goal), 
                method: :delete, 
                class: "btn btn-danger delete-btn",
                form: { style: 'display: inline;' },
                data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No goals have been created yet.</p>
  <% end %>
  
  <%= link_to "Back to Progress", root_path, class: "btn btn-link" %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const deleteButtons = document.querySelectorAll('.delete-btn');
  
  deleteButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      if (!confirm('Are you sure you want to delete this goal?')) {
        e.preventDefault();
        return false;
      }
    });
  });
});
</script>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
  }

  .goals-list {
    margin-top: 20px;
  }

  .goal-item {
    border: 1px solid #ddd;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .goal-info h3 {
    margin: 0 0 5px 0;
  }

  .goal-info p {
    margin: 0;
    color: #666;
  }

  .goal-actions {
    display: flex;
    gap: 10px;
  }

  .btn {
    display: inline-block;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 4px;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: #007bff;
    color: white;
  }

  .btn-secondary {
    background: #6c757d;
    color: white;
  }

  .btn-danger {
    background: #dc3545;
    color: white;
  }

  .btn-link {
    background: none;
    color: #007bff;
    text-decoration: underline;
  }
</style>
